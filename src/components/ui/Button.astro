---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'tertiary';
  class?: string;
}
const { href, variant = 'primary', class: className = '' } = Astro.props;

const base =
  'inline-flex items-center justify-center font-sans font-bold text-sm min-h-[48px] transition-all duration-300 ease-out';
const variants = {
  primary:
    'bg-clay hover:bg-clay-hover text-white rounded-full px-7 py-3 hover:shadow-[0_10px_30px_-14px_rgba(107,122,93,0.55)] hover:-translate-y-0.5',
  secondary:
    'bg-transparent border border-espresso text-espresso hover:bg-espresso hover:text-bone rounded-full px-7 py-3',
  tertiary:
    'text-clay hover:text-clay-hover px-0 py-1 underline underline-offset-[6px] decoration-1 decoration-clay/30 hover:decoration-clay hover:decoration-2 transition-all',
};
const cls = `${base} ${variants[variant]} ${className}`;
---
{href ? (
  <a href={href} class={cls}><slot /></a>
) : (
  <button type="button" class={cls}><slot /></button>
)}
