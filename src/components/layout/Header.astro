---
import Logo from '../ui/Logo.astro';
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';

const nav = [
  { href: '/apartments', label: 'Apartments' },
  { href: '/complex', label: 'The complex' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header id="site-header" class="sticky top-0 z-40 bg-bone/85 backdrop-blur border-b border-sand">
  <Container class="flex items-center justify-between py-4">
    <Logo tone="clay" size="sm" />

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-semibold">
      {
        nav.map((item) => {
          const active = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <a
              href={item.href}
              class:list={[
                'transition-colors',
                active ? 'text-clay' : 'text-espresso hover:text-clay',
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <div
        class="hidden sm:flex items-center gap-1 text-xs font-bold text-muted border border-sand rounded-full px-2 py-1"
      >
        <span class="text-espresso">EN</span>
        <span aria-hidden="true">·</span>
        <span>RO</span>
      </div>
      <div class="hidden md:block">
        <Button href="/apartments" variant="primary">Check availability</Button>
      </div>

      <!-- Mobile hamburger -->
      <button
        type="button"
        id="mobile-menu-toggle"
        class="md:hidden inline-flex items-center justify-center w-11 h-11 rounded-full border border-sand text-espresso hover:border-clay hover:text-clay transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-clay/40"
        aria-label="Open menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <svg
          width="20"
          height="14"
          viewBox="0 0 20 14"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path d="M1 1H19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
          <path d="M1 7H19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
          <path d="M1 13H13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </Container>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-bone opacity-0 pointer-events-none transition-opacity duration-300 ease-out md:hidden"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Main menu"
>
  <div class="flex flex-col h-full">
    <!-- Header row inside the drawer -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-sand">
      <Logo tone="clay" size="sm" />
      <button
        type="button"
        id="mobile-menu-close"
        class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-sand text-espresso hover:border-clay hover:text-clay transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-clay/40"
        aria-label="Close menu"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M2 2L14 14M14 2L2 14"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 overflow-y-auto px-6 py-10 flex flex-col gap-2">
      {
        nav.map((item, i) => {
          const active = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <a
              href={item.href}
              class:list={[
                'mobile-menu-link block font-serif text-4xl leading-tight border-b border-sand pb-4 transition-colors',
                active ? 'text-clay' : 'text-espresso hover:text-clay',
              ]}
              style={`--mm-delay:${i * 80}ms`}
            >
              {item.label}
            </a>
          );
        })
      }

      <div class="mt-10">
        <div class="text-[11px] uppercase tracking-[0.22em] text-muted-soft font-bold mb-3">
          Language
        </div>
        <div
          class="inline-flex items-center gap-2 border border-sand rounded-full px-3 py-2 text-sm font-bold"
        >
          <span class="text-espresso">EN</span>
          <span class="text-sand-strong" aria-hidden="true">·</span>
          <span class="text-muted">RO</span>
        </div>
      </div>
    </nav>

    <!-- Footer CTA -->
    <div class="px-6 py-6 border-t border-sand">
      <a
        href="/apartments"
        class="mobile-menu-cta block w-full text-center bg-clay hover:bg-clay-hover text-white rounded-full py-4 font-sans font-bold text-sm transition-colors"
      >
        Check availability
      </a>
    </div>
  </div>
</div>

<script>
  // Write the current header height into a CSS variable so sticky elements
  // below it (filter bars, booking widgets) can bind to a real value.
  function syncHeaderHeight() {
    const header = document.getElementById('site-header');
    if (!header) return;
    const h = Math.round(header.getBoundingClientRect().height);
    document.documentElement.style.setProperty('--header-h', h + 'px');
  }
  syncHeaderHeight();
  window.addEventListener('resize', syncHeaderHeight);
  document.addEventListener('astro:page-load', syncHeaderHeight);
  if ('ResizeObserver' in window) {
    const header = document.getElementById('site-header');
    if (header) new ResizeObserver(syncHeaderHeight).observe(header);
  }

  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const close = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;
    if ((menu as HTMLElement).dataset.bound === '1') return;
    (menu as HTMLElement).dataset.bound = '1';

    const open = () => {
      menu.classList.remove('opacity-0', 'pointer-events-none');
      menu.classList.add('opacity-100');
      menu.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      // stagger nav links + CTA
      const items = menu.querySelectorAll<HTMLElement>('.mobile-menu-link, .mobile-menu-cta');
      items.forEach((el, i) => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(10px)';
        el.style.transition =
          'opacity 500ms cubic-bezier(0.16, 1, 0.3, 1), transform 500ms cubic-bezier(0.16, 1, 0.3, 1)';
        el.style.transitionDelay = `${80 + i * 70}ms`;
        requestAnimationFrame(() => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        });
      });
    };
    const shut = () => {
      menu.classList.add('opacity-0', 'pointer-events-none');
      menu.classList.remove('opacity-100');
      menu.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', open);
    close?.addEventListener('click', shut);
    // Close on link click (before navigation) so it doesn't linger during view transitions.
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', shut));
    // Escape closes.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.getAttribute('aria-hidden') === 'false') shut();
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
  // Make sure body scroll is unlocked after any client-router navigation.
  document.addEventListener('astro:after-swap', () => {
    document.body.style.overflow = '';
  });
</script>
