---
import Layout from '../layouts/Layout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import DateRangePicker from '../components/booking/DateRangePicker.tsx';
import GuestPicker from '../components/booking/GuestPicker.tsx';
import ApartmentPicker from '../components/booking/ApartmentPicker.tsx';
import Map from '../components/content/Map.astro';
import { apartments } from '../data/apartments';
import { location } from '../data/location';

const apartmentOptions = apartments.map((a) => ({
  slug: a.slug,
  name: a.name,
  type: a.type,
  size: a.size,
  guests: a.guests,
  gradient: a.gradient,
}));

const channels = [
  {
    label: 'WhatsApp',
    detail: location.phone,
    note: 'Fastest — typically under 10 minutes, 08:00–22:00 EET.',
    href: location.whatsappHref,
    tag: 'Recommended',
  },
  {
    label: 'Phone',
    detail: location.phone,
    note: 'Front desk, 24/7.',
    href: location.phoneHref,
  },
  {
    label: 'Email',
    detail: location.email,
    note: 'For inquiries longer than one paragraph.',
    href: `mailto:${location.email}`,
  },
  {
    label: 'Address',
    detail: location.addressShort,
    note: 'GPS locator sent 48h before check-in.',
    href: '#',
  },
];

const practicals = [
  {
    title: 'Check-in',
    body: 'From 15:00. Self check-in with a keycode — no queue, no reception line. Earlier arrivals can drop luggage from 11:00.',
  },
  {
    title: 'Check-out',
    body: 'Until 11:00. Late check-out until 14:00 is often possible on request — ask the day before.',
  },
  {
    title: 'Parking',
    body: 'Free underground parking with EV charging. Registration on arrival takes a minute at the concierge desk.',
  },
  {
    title: 'House rules',
    body: 'No smoking indoors, no events. Pets welcome by prior arrangement. Quiet hours 22:00–08:00 out of respect for residents.',
  },
];

const faqs = [
  {
    q: 'Is booking direct really the best rate?',
    a: 'Yes. The price you see here is our best available rate — no OTA commission, no separate cleaning surcharge added at the last step. If you find a lower publicly listed rate for the same dates, we match it.',
  },
  {
    q: 'Are the resort amenities really free?',
    a: 'Yes — pool, sauna, gym, courts, indoor recreation and the kids’ area are all included with every stay. There is no day pass, no per-visit fee, no locker rental.',
  },
  {
    q: 'How does self check-in work?',
    a: 'Two days before arrival you receive a message with a keycode and an arrival guide (parking, lift, apartment, Wi-Fi). No key handover, no reception queue.',
  },
  {
    q: 'What is the cancellation policy?',
    a: 'Free cancellation up to 48 hours before check-in for direct bookings. OTA cancellations follow the OTA’s policy.',
  },
  {
    q: 'Can I bring my dog?',
    a: 'Yes, with prior arrangement — one small-to-medium dog per apartment, under 15 kg. A small cleaning surcharge applies. Let us know in the inquiry form.',
  },
  {
    q: 'Do you host long stays or corporate bookings?',
    a: 'Yes. Stays of 14 nights or more get a lower nightly rate, and we handle invoicing for corporate bookings. Send us dates and we will come back with a quote.',
  },
];
---
<Layout title="Contact & FAQ — YamaLuxe">

  <!-- Split hero: form left, channels right -->
  <section class="pt-14 md:pt-20 pb-24">
    <Container>
      <div class="text-[13px] uppercase tracking-[0.22em] text-clay font-bold mb-5">Contact</div>
      <h1 class="font-serif font-medium text-5xl md:text-6xl leading-[1.05] tracking-tight max-w-3xl">
        Talk to a human. <em class="text-clay not-italic font-medium"><span class="italic">Usually within the hour.</span></em>
      </h1>
      <p class="mt-6 max-w-xl text-lg text-muted leading-relaxed">
        Send a message, or reach out directly on WhatsApp or the phone. Someone here reads every inquiry.
      </p>

      <div class="mt-14 grid gap-10 lg:grid-cols-[1.15fr_0.85fr]">
        <!-- Form -->
        <form class="bg-warm-white border border-sand rounded-2xl p-6 md:p-8 space-y-5" action="#" method="post">
          <div class="grid gap-5 md:grid-cols-2">
            <label class="block">
              <span class="block text-[11px] uppercase tracking-[0.18em] text-muted-soft font-bold mb-1">Name</span>
              <input type="text" required class="w-full bg-bone border border-sand rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-clay" />
            </label>
            <label class="block">
              <span class="block text-[11px] uppercase tracking-[0.18em] text-muted-soft font-bold mb-1">Email</span>
              <input type="email" required class="w-full bg-bone border border-sand rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-clay" />
            </label>
          </div>
          <div class="grid gap-5 md:grid-cols-[2fr_1fr]">
            <DateRangePicker variant="compact" name="stay" client:visible />
            <GuestPicker variant="field" maxTotal={6} name="guests" client:visible />
          </div>
          <ApartmentPicker options={apartmentOptions} label="Apartment (optional)" name="apartment" client:visible />
          <label class="block">
            <span class="block text-[11px] uppercase tracking-[0.18em] text-muted-soft font-bold mb-1">Message</span>
            <textarea rows="5" required class="w-full bg-bone border border-sand rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-clay resize-y" placeholder="Any questions, special requests, dietary needs, celebrations — anything worth knowing."></textarea>
          </label>
          <div class="flex flex-wrap items-center justify-between gap-3">
            <p class="text-[11px] text-muted-soft max-w-xs">By submitting you agree to our privacy notice. Typical reply within one hour, 08:00–22:00 EET.</p>
            <Button variant="primary">Send inquiry</Button>
          </div>
        </form>

        <!-- Direct channels -->
        <aside class="space-y-4">
          {channels.map((c, i) => (
            <a
              href={c.href}
              class="reveal lift block bg-warm-white border border-sand rounded-2xl p-6 group"
              style={`--reveal-delay:${i * 100}ms`}
            >
              <div class="flex items-baseline justify-between gap-2">
                <div class="text-[11px] uppercase tracking-[0.22em] text-muted-soft font-bold">{c.label}</div>
                {c.tag && <span class="text-[10px] uppercase tracking-[0.18em] bg-clay text-white rounded-full px-2 py-0.5 font-bold">{c.tag}</span>}
              </div>
              <div class="font-serif text-2xl mt-2 text-espresso group-hover:text-clay transition-colors">{c.detail}</div>
              <p class="text-xs text-muted mt-2">{c.note}</p>
            </a>
          ))}
        </aside>
      </div>
    </Container>
  </section>

  <!-- Practical info -->
  <section id="rules" class="py-24 bg-warm-white border-y border-sand">
    <Container>
      <SectionHeading
        eyebrow="Practical"
        title="Check-in and everything before arrival."
      />
      <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {practicals.map((p, i) => (
          <div class="reveal border-t border-sand pt-6" style={`--reveal-delay:${i * 100}ms`}>
            <h3 class="font-serif text-2xl">{p.title}</h3>
            <p class="mt-3 text-sm text-muted leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- FAQ accordion -->
  <section id="faq" class="py-24">
    <Container>
      <div class="grid gap-12 lg:grid-cols-[1fr_2fr]">
        <div>
          <SectionHeading
            eyebrow="FAQ"
            title="Things guests ask before booking."
          />
          <p class="mt-6 text-sm text-muted">Not answered here? Send us a message — that is what the form above is for.</p>
        </div>
        <div class="border-t border-sand">
          {faqs.map((f) => (
            <details class="group border-b border-sand py-5">
              <summary class="cursor-pointer flex items-start justify-between gap-4 list-none">
                <span class="font-serif text-xl md:text-2xl leading-snug">{f.q}</span>
                <span class="text-clay text-2xl leading-none flex-shrink-0 transition-transform group-open:rotate-45">+</span>
              </summary>
              <p class="mt-4 text-muted leading-relaxed max-w-2xl">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Map -->
  <section class="py-16 bg-warm-white border-y border-sand">
    <Container>
      <Map lat={location.lat} lng={location.lng} zoom={15} height="aspect-[4/5] sm:aspect-[16/9] md:aspect-[21/9]" markerTitle={`YamaLuxe Apartments — ${location.addressShort}`} />
    </Container>
  </section>

</Layout>
