---
import { Image, getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import ApartmentCard from '../../components/content/ApartmentCard.astro';
import BookingBand from '../../components/booking/BookingBand.astro';
import DateRangePicker from '../../components/booking/DateRangePicker.tsx';
import GuestPicker from '../../components/booking/GuestPicker.tsx';
import Map from '../../components/content/Map.astro';
import ReviewsGrid from '../../components/content/ReviewsGrid.astro';
import { apartments, getSimilarApartments, getApartmentPhotos } from '../../data/apartments';
import { getReviews } from '../../data/reviews';
import { location } from '../../data/location';

export function getStaticPaths() {
  return apartments.map((apt) => ({
    params: { slug: apt.slug },
    props: { apt },
  }));
}

const { apt } = Astro.props;
const similar = getSimilarApartments(apt.slug, 2);
const photos = getApartmentPhotos(apt.slug);
const lead = photos[0];
const secondary = photos[1];
const tertiary = photos[2];

// Pre-resolve full-size URLs for the PhotoSwipe lightbox (bigger images than the thumbnail widths above).
const fullSize = await Promise.all(
  photos.map(async (src) => {
    const opt = await getImage({ src, format: 'webp', width: 1920 });
    return {
      url: opt.src,
      width: opt.attributes.width ?? 1920,
      height: opt.attributes.height ?? 1080,
    };
  }),
);

const aptReviews = getReviews(2, apt.slug);
---

<Layout title={`${apt.name} — YamaLuxe`}>
  <!-- Breadcrumb -->
  <Container class="pt-8 text-xs text-muted-soft">
    <a href="/apartments" class="hover:text-clay">← All apartments</a>
  </Container>

  <!-- 01 · GALLERY -->
  <section class="pt-6 pb-12">
    <Container>
      <div id="apt-gallery" class="grid gap-4 md:grid-cols-[1.6fr_1fr]">
        {
          lead && (
            <a
              href={fullSize[0].url}
              data-pswp-width={fullSize[0].width}
              data-pswp-height={fullSize[0].height}
              class="reveal-scale block group rounded-2xl overflow-hidden aspect-[4/3] md:aspect-[16/11] bg-sand relative"
            >
              <Image
                src={lead}
                alt={`${apt.name} — main view`}
                widths={[600, 900, 1400]}
                sizes="(min-width: 768px) 62vw, 100vw"
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
              />
            </a>
          )
        }

        <div class="grid grid-cols-2 md:grid-cols-1 md:grid-rows-2 gap-4">
          {
            secondary && (
              <a
                href={fullSize[1].url}
                data-pswp-width={fullSize[1].width}
                data-pswp-height={fullSize[1].height}
                class="block group rounded-2xl overflow-hidden aspect-[4/3] bg-sand"
              >
                <Image
                  src={secondary}
                  alt={`${apt.name} — detail`}
                  widths={[300, 500, 700]}
                  sizes="(min-width: 768px) 30vw, 45vw"
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                />
              </a>
            )
          }
          {
            tertiary && (
              <a
                href={fullSize[2].url}
                data-pswp-width={fullSize[2].width}
                data-pswp-height={fullSize[2].height}
                class="block group rounded-2xl overflow-hidden aspect-[4/3] bg-sand"
              >
                <Image
                  src={tertiary}
                  alt={`${apt.name} — detail`}
                  widths={[300, 500, 700]}
                  sizes="(min-width: 768px) 30vw, 45vw"
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                />
              </a>
            )
          }
        </div>

        <!-- Hidden anchors for remaining photos so they open in the lightbox but aren't shown in the grid -->
        {
          photos.slice(3).map((_, i) => (
            <a
              href={fullSize[i + 3].url}
              data-pswp-width={fullSize[i + 3].width}
              data-pswp-height={fullSize[i + 3].height}
              class="hidden"
              aria-hidden="true"
            >
              <span class="sr-only">Photo {i + 4}</span>
            </a>
          ))
        }
      </div>
      <div class="mt-3 flex items-center gap-3">
        <button
          type="button"
          id="view-all-photos"
          class="text-xs font-bold text-clay hover:text-clay-hover"
        >
          View all {photos.length} photos →
        </button>
      </div>
    </Container>
  </section>

  <!-- 02 · TITLE + SPECS + STICKY BOOKING -->
  <section class="pb-24">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[1.4fr_0.9fr] lg:gap-16">
        <div>
          <div class="text-[11px] uppercase tracking-[0.22em] text-clay font-bold mb-3">
            {apt.type} · Bucharest
          </div>
          <h1 class="font-serif font-medium text-5xl md:text-[56px] leading-[1.05] tracking-tight">
            {apt.name}
          </h1>
          <p class="mt-4 text-lg text-muted">{apt.tagline}</p>

          <dl class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-6 border-y border-sand py-8">
            <div>
              <dt class="text-[11px] uppercase tracking-[0.18em] text-muted-soft font-bold">
                Size
              </dt>
              <dd class="font-serif text-2xl mt-1">{apt.size}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.18em] text-muted-soft font-bold">
                Sleeps
              </dt>
              <dd class="font-serif text-2xl mt-1">{apt.guests} guests</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.18em] text-muted-soft font-bold">
                Beds
              </dt>
              <dd class="font-serif text-2xl mt-1">{apt.beds}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.18em] text-muted-soft font-bold">
                Baths
              </dt>
              <dd class="font-serif text-2xl mt-1">{apt.baths}</dd>
            </div>
          </dl>

          <div class="mt-10 max-w-2xl">
            <h2 class="font-serif text-3xl">About this apartment</h2>
            <p class="mt-4 text-muted leading-relaxed">{apt.description}</p>
          </div>

          <!-- Amenities -->
          <div class="mt-14 grid gap-10 md:grid-cols-2">
            <div>
              <div class="text-[11px] uppercase tracking-[0.22em] text-clay font-bold mb-4">
                In the apartment
              </div>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-2 text-sm">
                {
                  apt.inApartment.map((a) => (
                    <li class="flex items-center gap-2">
                      <span class="text-clay">·</span>
                      {a}
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <div class="text-[11px] uppercase tracking-[0.22em] text-clay font-bold mb-4">
                In the complex
              </div>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-2 text-sm">
                {
                  apt.complexAccess.map((a) => (
                    <li class="flex items-center gap-2">
                      <span class="text-clay">·</span>
                      {a}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <!-- Sticky booking widget -->
        <aside class="lg:sticky lg:self-start" style="top: calc(var(--header-h, 68px) + 24px);">
          <div
            class="reveal bg-warm-white border border-sand rounded-2xl p-6 shadow-[0_1px_0_rgba(180,116,79,0.06)]"
            style="--reveal-delay:120ms"
          >
            <div class="flex items-baseline justify-between">
              <div>
                <span class="font-serif text-3xl">€{apt.priceFrom}</span>
                <span class="text-muted text-sm"> / night from</span>
              </div>
              <div class="text-xs text-muted-soft">Best rate · direct</div>
            </div>
            <form class="mt-5 space-y-3">
              <DateRangePicker variant="stack" client:visible align="right" />
              <GuestPicker variant="field" maxTotal={apt.guests} align="right" client:visible />
              <Button variant="primary" class="w-full">Reserve now</Button>
              <p class="text-[11px] text-muted-soft text-center">
                You will not be charged yet — availability check first.
              </p>
            </form>
            <div class="mt-5 pt-5 border-t border-sand text-xs text-muted space-y-1">
              <div>✦ Free cancellation up to 48h</div>
              <div>✦ Self check-in, 24/7 WhatsApp</div>
              <div>✦ Best-rate guarantee</div>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- 03 · LOCATION SNIPPET -->
  <section class="py-16 bg-warm-white border-y border-sand">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[1fr_1.2fr] items-center">
        <div>
          <SectionHeading
            eyebrow="Where you stay"
            title="Quiet complex, city on hand."
            intro="A residential enclave with quick lines to the airport and the old town — parking, security, and 24/7 access."
          />
        </div>
        <Map
          lat={location.lat}
          lng={location.lng}
          zoom={15}
          height="aspect-[4/5] sm:aspect-square md:aspect-[16/9]"
          markerTitle={apt.name}
        />
      </div>
    </Container>
  </section>

  <!-- 04 · REVIEWS — compact, no section heading (Home carries the reviews section) -->
  <section class="py-12">
    <Container>
      <div class="text-[11px] uppercase tracking-[0.22em] text-muted-soft font-bold mb-6">
        Stayed here
      </div>
      <ReviewsGrid reviews={aptReviews} tone="warm" />
    </Container>
  </section>

  <!-- 05 · SIMILAR -->
  {
    similar.length > 0 && (
      <section class="py-16 bg-warm-white border-y border-sand">
        <Container>
          <SectionHeading eyebrow="Similar apartments" title="You might also like." />
          <div class="mt-10 grid gap-6 md:grid-cols-2">
            {similar.map((a) => (
              <ApartmentCard apt={a} />
            ))}
          </div>
        </Container>
      </section>
    )
  }

  <BookingBand />

  <!-- Mobile-only sticky book bar (Airbnb/Booking pattern) -->
  <div
    class="lg:hidden fixed bottom-0 left-0 right-0 z-40 bg-warm-white/95 backdrop-blur border-t border-sand px-4 py-3 flex items-center justify-between gap-3 shadow-[0_-4px_16px_-8px_rgba(31,30,26,0.10)]"
  >
    <div>
      <div class="font-serif text-xl leading-none">
        €{apt.priceFrom}<span class="text-muted text-sm font-sans"> / night</span>
      </div>
      <div class="text-[10px] uppercase tracking-[0.18em] text-muted-soft font-bold mt-1">
        Best rate · direct
      </div>
    </div>
    <a
      href="#booking"
      class="inline-flex items-center justify-center bg-clay hover:bg-clay-hover text-white rounded-full px-6 py-3 font-sans font-bold text-sm transition-colors"
    >
      Reserve
    </a>
  </div>
  <!-- Spacer so the sticky bar doesn't cover the footer content -->
  <div class="lg:hidden h-20" aria-hidden="true"></div>
</Layout>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const gallery = document.getElementById('apt-gallery');
  if (gallery) {
    const lightbox = new PhotoSwipeLightbox({
      gallery: '#apt-gallery',
      children: 'a[data-pswp-width]',
      pswpModule: () => import('photoswipe'),
      bgOpacity: 0.94,
      wheelToZoom: true,
      loop: false,
    });
    lightbox.init();

    const viewAll = document.getElementById('view-all-photos');
    viewAll?.addEventListener('click', () => {
      lightbox.loadAndOpen(0);
    });
  }
</script>

<style is:global>
  .pswp {
    --pswp-bg: #1f1e1a;
    --pswp-placeholder-bg: #3a342e;
    --pswp-icon-color: #f5f1e8;
    --pswp-icon-color-secondary: #1f1e1a;
    --pswp-icon-stroke-color: #1f1e1a;
  }
</style>
