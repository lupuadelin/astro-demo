---
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/ui/Container.astro';
import ApartmentCard from '../../components/content/ApartmentCard.astro';
import BookingBand from '../../components/booking/BookingBand.astro';
import GuestPicker from '../../components/booking/GuestPicker.tsx';
import { apartments } from '../../data/apartments';

const types = ['All', 'Studio', '2-room', '3-room'];
const amenityChips = ['Pool access', 'Sauna access', 'Balcony', 'Full kitchen', 'Two baths', 'Nespresso'];
---
<Layout title="Apartments — YamaLuxe">

  <!-- Compact hero -->
  <section class="pt-14 md:pt-20 pb-10">
    <Container>
      <div class="text-[13px] uppercase tracking-[0.22em] text-clay font-bold mb-5">Apartments</div>
      <h1 class="font-serif font-medium text-5xl md:text-6xl leading-[1.05] tracking-tight max-w-3xl">
        Three apartments. One standard.
      </h1>
      <p class="mt-6 max-w-xl text-lg text-muted leading-relaxed">
        Studios and family-sized. Every apartment includes pool, sauna and gym access — nothing to add at checkout.
      </p>
    </Container>
  </section>

  <!-- Sticky filter bar -->
  <div class="sticky z-30 bg-bone/85 backdrop-blur border-y border-sand" style="top: var(--header-h, 68px);">
    <Container class="py-4">
      <form
        id="apt-filters"
        class="flex flex-wrap items-center gap-3 md:gap-4 text-sm"
        aria-label="Apartment filters"
      >
        <!-- Type -->
        <div class="flex items-center gap-2 flex-wrap" role="radiogroup" aria-label="Apartment type">
          <span class="text-[11px] uppercase tracking-[0.18em] text-muted-soft font-bold mr-1">Type</span>
          {types.map((t, i) => (
            <label class="cursor-pointer">
              <input type="radio" name="type" value={t} class="sr-only peer" checked={i === 0} />
              <span class="inline-block px-4 py-2 rounded-full border border-sand text-espresso font-semibold text-xs
                peer-checked:bg-clay peer-checked:text-white peer-checked:border-clay
                hover:border-clay transition-colors">{t}</span>
            </label>
          ))}
        </div>

        <span class="hidden md:block w-px h-6 bg-sand"></span>

        <!-- Guests — used as minimum-capacity filter -->
        <div class="w-full md:w-[180px]">
          <GuestPicker variant="field" name="guests" maxTotal={8} client:load />
        </div>

        <span class="hidden md:block w-px h-6 bg-sand"></span>

        <!-- Amenity chips -->
        <div class="flex items-center gap-2 flex-wrap" role="group" aria-label="Amenity chips">
          <span class="text-[11px] uppercase tracking-[0.18em] text-muted-soft font-bold mr-1">Amenities</span>
          {amenityChips.map((a) => (
            <label class="cursor-pointer">
              <input type="checkbox" name="amenity" value={a} class="sr-only peer" />
              <span class="inline-block px-3 py-1.5 rounded-full border border-sand text-espresso font-semibold text-xs
                peer-checked:bg-espresso peer-checked:text-bone peer-checked:border-espresso
                hover:border-clay transition-colors">{a}</span>
            </label>
          ))}
        </div>

        <button type="button" id="apt-reset" class="ml-auto text-xs font-bold text-clay hover:text-clay-hover">Reset</button>
      </form>
    </Container>
  </div>

  <!-- Grid -->
  <section class="py-12 md:py-16">
    <Container>
      <div class="flex items-baseline mb-8">
        <div class="text-sm text-muted"><span id="apt-count" class="text-espresso font-bold">{apartments.length}</span> apartments</div>
      </div>

      <div id="apt-grid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {apartments.map((apt) => <ApartmentCard apt={apt} />)}
      </div>

      <div id="apt-empty" class="hidden text-center py-24">
        <div class="font-serif text-3xl">No apartments match those filters.</div>
        <p class="mt-3 text-muted">Loosen a filter, or reset.</p>
      </div>
    </Container>
  </section>

  <BookingBand />

</Layout>

<script>
  const form = document.getElementById('apt-filters') as HTMLFormElement | null;
  const grid = document.getElementById('apt-grid');
  const countEl = document.getElementById('apt-count');
  const emptyEl = document.getElementById('apt-empty');
  const resetBtn = document.getElementById('apt-reset');
  if (form && grid && countEl && emptyEl) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-apt-card]'));

    function applyFilters() {
      const data = new FormData(form!);
      const type = String(data.get('type') ?? 'All');
      // GuestPicker emits guestsAdults + guestsChildren + guestsInfants as hidden inputs.
      // Sum adults + children as the minimum-capacity threshold (infants don't count toward capacity).
      const adults = Number(data.get('guestsAdults') ?? 0);
      const children = Number(data.get('guestsChildren') ?? 0);
      const guestsMin = adults + children;
      const amenities = data.getAll('amenity').map((v) => String(v).toLowerCase());

      let visible = 0;
      cards.forEach((card) => {
        const cardType = card.dataset.type ?? '';
        const cardGuests = Number(card.dataset.guests ?? 0);
        const cardAmenities = (card.dataset.amenities ?? '').split('|');
        const matchType = type === 'All' || cardType === type;
        const matchGuests = cardGuests >= guestsMin;
        const matchAmenities = amenities.every((a) => cardAmenities.includes(a));
        const show = matchType && matchGuests && matchAmenities;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      countEl!.textContent = String(visible);
      emptyEl!.classList.toggle('hidden', visible > 0);
      grid!.classList.toggle('hidden', visible === 0);
    }

    form.addEventListener('change', applyFilters);
    resetBtn?.addEventListener('click', () => {
      form.reset();
      applyFilters();
    });
  }
</script>
