---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import BookingBand from '../components/booking/BookingBand.astro';
import Map from '../components/content/Map.astro';
import LocationStats from '../components/content/LocationStats.astro';
import { getComplexPhotos } from '../data/apartments';
import { location } from '../data/location';

const photos = getComplexPhotos();
// Three images spread far apart in the sequence so they read as distinct shots.
const atmospherePhoto = photos[0];
const midpointPhoto = photos[10] ?? photos[7] ?? photos[1];
const bookingPhoto = photos[5] ?? photos[2];

const poolChips = ['Heated to 28 °C', '25-metre lanes', 'Open 06:00 – 22:00', 'Towels provided'];
const saunaChips = ['80 °C dry', '30-minute private slots', 'Two levels · cooling area'];
const gymChips = ['05:30 – 23:00', 'Dumbbells to 40 kg', 'Two treadmills, one rower'];
const courtsChips = ['Tennis, padel, basketball', 'Lit until 22:00', 'Rackets and balls at reception'];
const indoorChips = ['Table tennis, billiards', 'Board-game library', 'Coffee bar until 22:00'];
const kidsChips = ['Soft play, ages 2 – 8', 'Outdoor climbing frame', 'Weekend film screenings'];

const extras = [
  'Underground parking',
  'EV charging',
  '24/7 concierge',
  'Bike storage',
  'On-site laundry',
];
---
<Layout title="The Complex — YamaLuxe">

  <!-- ============ HERO — text-only, editorial ============ -->
  <section class="pt-12 md:pt-24 lg:pt-32 pb-10 md:pb-16">
    <Container>
      <div class="text-[12px] md:text-[13px] uppercase tracking-[0.22em] text-clay font-bold mb-5 md:mb-8">The complex</div>

      <h1 class="reveal font-serif font-medium text-[40px] md:text-6xl lg:text-[80px] leading-[1.0] tracking-tight max-w-5xl">
        A residential complex that behaves like a hotel.
      </h1>

      <div class="mt-6 md:mt-10 max-w-xl text-base md:text-lg text-muted leading-relaxed">
        Six amenity spaces, one lift ride from your bed. All included with your stay — no day passes, no wristbands, nothing to add at checkout.
      </div>

      <div class="mt-10 md:mt-16 grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-6 border-t border-sand pt-8 md:pt-10">
        {[
          { label: 'Amenity spaces', value: '6' },
          { label: 'Included', value: 'All of them' },
          { label: 'Reception', value: '24 / 7' },
          { label: 'Booking required', value: 'Sauna & courts' },
        ].map((s) => (
          <div class="reveal">
            <div class="text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-muted-soft font-bold">{s.label}</div>
            <div class="font-serif text-xl md:text-2xl mt-1.5 md:mt-2">{s.value}</div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ============ ESTABLISHING IMAGE (moved above the quote) ============ -->
  <section class="pt-4 md:pt-8 pb-2 md:pb-4">
    <Container>
      <div class="reveal-scale rounded-3xl overflow-hidden bg-sand aspect-[4/5] sm:aspect-[16/10] lg:aspect-[21/9]">
        {atmospherePhoto && (
          <Image
            src={atmospherePhoto}
            alt="Inside YamaLuxe"
            widths={[500, 800, 1200, 1600, 1920]}
            sizes="(min-width: 1024px) 1120px, 100vw"
            class="w-full h-full object-cover"
          />
        )}
      </div>
    </Container>
  </section>

  <!-- ============ PULL QUOTE (now lands after the image, works as caption) ============ -->
  <section class="py-10 md:py-24">
    <Container>
      <blockquote class="reveal max-w-4xl font-serif text-2xl md:text-[44px] leading-[1.2] md:leading-[1.15] text-espresso text-balance">
        <span class="text-sand-strong font-serif text-5xl md:text-6xl leading-none align-top mr-2">“</span>Most rentals give you a bed and a Wi-Fi password. We wanted to give you the pool at sunset, too — without asking you to pay for it twice.
      </blockquote>
      <div class="reveal mt-5 md:mt-6 text-[11px] uppercase tracking-[0.22em] text-muted-soft font-bold" style="--reveal-delay:120ms">
        — Ioana, host
      </div>
    </Container>
  </section>

  <!-- ============ THE POOL — typography only (no misleading photo) ============ -->
  <section class="py-14 md:py-24 bg-warm-white border-y border-sand">
    <Container>
      <div class="max-w-4xl">
        <div class="reveal text-[11px] uppercase tracking-[0.22em] text-clay font-bold mb-3 md:mb-4">01 · The pool</div>
        <h2 class="reveal font-serif font-medium text-4xl md:text-[68px] leading-[1.02] mb-5 md:mb-8" style="--reveal-delay:80ms">
          Twenty-five metres of it. Yours.
        </h2>
        <p class="reveal text-muted leading-relaxed max-w-xl text-base md:text-lg" style="--reveal-delay:160ms">
          Heated year-round to 28 °C. Six cabana chairs on the sun deck, a shallow-end lane for laps. Quietest between 06:00 and 10:00.
        </p>
        <ul class="reveal mt-6 md:mt-10 flex flex-wrap gap-2" style="--reveal-delay:240ms">
          {poolChips.map((c) => (
            <li class="border border-sand rounded-full px-3.5 md:px-4 py-1.5 md:py-2 text-xs font-semibold text-espresso bg-bone">{c}</li>
          ))}
        </ul>
      </div>
    </Container>
  </section>

  <!-- ============ BATHHOUSE + TRAINING (typography only) ============ -->
  <section class="py-14 md:py-24">
    <Container>
      <div class="grid gap-6 md:grid-cols-2 md:gap-24 items-start">
        <article class="reveal border-t border-sand pt-6 md:pt-8">
          <div class="text-[11px] uppercase tracking-[0.22em] text-clay font-bold mb-3">02 · Bathhouse</div>
          <h2 class="font-serif font-medium text-3xl md:text-5xl leading-[1.05] md:leading-[1.02]">Finnish sauna</h2>
          <p class="mt-4 md:mt-5 text-muted leading-relaxed max-w-md text-base">
            Cedar-lined, two levels, a cooling area next door. Bookable in private slots at the desk, or open-use during off-peak.
          </p>
          <ul class="mt-6 md:mt-8 divide-y divide-sand text-sm">
            {saunaChips.map((c) => (
              <li class="py-2.5 md:py-3 text-espresso font-medium">{c}</li>
            ))}
          </ul>
        </article>

        <article class="reveal md:mt-16 border-t border-sand pt-6 md:pt-8" style="--reveal-delay:140ms">
          <div class="text-[11px] uppercase tracking-[0.22em] text-clay font-bold mb-3">03 · Training</div>
          <h2 class="font-serif font-medium text-3xl md:text-5xl leading-[1.05] md:leading-[1.02]">The gym.</h2>
          <p class="mt-4 md:mt-5 text-muted leading-relaxed max-w-md text-base">
            Racks, dumbbells and a rower. Nothing gimmicky — everything you would actually use, room to move between them.
          </p>
          <ul class="mt-6 md:mt-8 divide-y divide-sand text-sm">
            {gymChips.map((c) => (
              <li class="py-2.5 md:py-3 text-espresso font-medium">{c}</li>
            ))}
          </ul>
        </article>
      </div>
    </Container>
  </section>

  <!-- ============ MIDPOINT BREATH IMAGE (between Training and Play) ============ -->
  <section class="pb-4 md:pb-8">
    <Container>
      <div class="reveal-scale rounded-2xl overflow-hidden bg-sand aspect-[4/5] sm:aspect-[16/9] md:aspect-[21/8] lg:aspect-[3/1]">
        {midpointPhoto && (
          <Image
            src={midpointPhoto}
            alt="A YamaLuxe apartment"
            widths={[500, 900, 1400, 1920]}
            sizes="(min-width: 1024px) 1120px, 100vw"
            class="w-full h-full object-cover"
          />
        )}
      </div>
    </Container>
  </section>

  <!-- ============ RECREATION (typographic 3-up) ============ -->
  <section class="py-14 md:py-24 bg-warm-white border-y border-sand">
    <Container>
      <div class="max-w-2xl">
        <div class="reveal text-[11px] uppercase tracking-[0.22em] text-clay font-bold mb-3">04 · Play</div>
        <h2 class="reveal font-serif font-medium text-3xl md:text-5xl leading-[1.05]" style="--reveal-delay:100ms">
          For the courts and the rainy days.
        </h2>
      </div>

      <div class="mt-8 md:mt-16 grid gap-6 md:grid-cols-3 md:gap-10">
        <article class="reveal border-t border-sand pt-5 md:pt-6" style="--reveal-delay:0ms">
          <h3 class="font-serif text-2xl md:text-3xl">Sports courts</h3>
          <ul class="mt-4 flex flex-wrap gap-2">
            {courtsChips.map((c) => (
              <li class="border border-sand rounded-full px-3 py-1.5 text-xs font-semibold text-espresso bg-bone">{c}</li>
            ))}
          </ul>
        </article>

        <article class="reveal border-t border-sand pt-5 md:pt-6" style="--reveal-delay:100ms">
          <h3 class="font-serif text-2xl md:text-3xl">Indoor recreation</h3>
          <ul class="mt-4 flex flex-wrap gap-2">
            {indoorChips.map((c) => (
              <li class="border border-sand rounded-full px-3 py-1.5 text-xs font-semibold text-espresso bg-bone">{c}</li>
            ))}
          </ul>
        </article>

        <article class="reveal border-t border-sand pt-5 md:pt-6" style="--reveal-delay:200ms">
          <h3 class="font-serif text-2xl md:text-3xl">Kids' area</h3>
          <ul class="mt-4 flex flex-wrap gap-2">
            {kidsChips.map((c) => (
              <li class="border border-sand rounded-full px-3 py-1.5 text-xs font-semibold text-espresso bg-bone">{c}</li>
            ))}
          </ul>
        </article>
      </div>
    </Container>
  </section>

  <!-- ============ EVERYTHING ELSE — serif inline list ============ -->
  <section class="py-10 md:py-16">
    <Container>
      <div class="border-y border-sand py-8 md:py-10">
        <div class="text-[11px] uppercase tracking-[0.22em] text-clay font-bold mb-4">Also included</div>

        <!-- Mobile: stacked, dividers -->
        <ul class="md:hidden divide-y divide-sand">
          {extras.map((e) => (
            <li class="py-2.5 font-serif text-xl leading-snug text-espresso">{e}</li>
          ))}
        </ul>

        <!-- Desktop: inline serif with dot separators -->
        <p class="hidden md:block font-serif text-2xl md:text-3xl leading-snug text-espresso">
          {extras.map((e, i) => (
            <>
              {e}
              {i < extras.length - 1 && <span class="text-sand-strong mx-3">·</span>}
            </>
          ))}
        </p>
      </div>
    </Container>
  </section>

  <!-- ============ LOCATION ============ -->
  <section class="py-14 md:py-24">
    <Container>
      <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr] items-center">
        <div>
          <SectionHeading
            eyebrow="Location"
            title="Quiet residence, city on hand."
            intro="Gated complex, 24/7 concierge, underground parking with EV charging, and the metro six minutes on foot."
          />
          <LocationStats class="mt-10" columns={2} />
        </div>
        <Map lat={location.lat} lng={location.lng} zoom={14} height="aspect-[4/5] sm:aspect-square md:aspect-[16/11]" markerTitle="The YamaLuxe complex" />
      </div>
    </Container>
  </section>

  <BookingBand
    eyebrow="Come for the apartment. Stay for the complex."
    title="Book direct — every amenity is already included."
    photo={bookingPhoto}
    photoAlt="A view inside the complex"
  />

</Layout>
